# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/depokemongo
REDIS_URL=redis://localhost:6379

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# General server signer for Anchor interactions and NFT minting.
ANCHOR_WALLET=./wallet/anchor-wallet.json
# Production alternative to shipping a wallet file. Use a base64-encoded JSON keypair array.
ANCHOR_WALLET_SECRET=
# Dedicated PIKO mint authority wallet. Keep this outside the repo in production.
PIKO_MINT_AUTHORITY_WALLET=/secure/path/mint-authority.json
PIKO_MINT_ADDRESS=YOUR_PIKO_TOKEN_MINT_PUBKEY_HERE_1234567890
PIKO_DECIMALS=9
NFT_REWARDS_ENABLED=false
NFT_REWARD_SYMBOL=CPN
NFT_REWARD_METADATA_BASE_URI=https://piko-protocol-web.vercel.app/metadata/
NFT_REWARD_METADATA_TEMPLATE=contributor.json
NFT_REWARD_IMAGE_URL=https://piko-protocol-web.vercel.app/nft/contributor-proof.svg
PIKO_DAILY_WALLET_CAP_BASE_UNITS=1000000000000
REWARD_COOLDOWN_SECONDS=60
MERCHANT_REGISTRY_PROGRAM_ID=
QUEST_PROGRAM_ID=
SOLANA_PAY_FALLBACK_RECIPIENT=GvHeQ9NfL7KPLWjXrbgNqE6W5gK4Tz6M3fVhHq7w8Y9Z

# AI
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=PIKO Protocol
# Agents use Ollama first and fall back to deterministic rules when local inference is unavailable.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# App
NEXT_PUBLIC_API_URL=http://localhost:3001
# Vercel production should use:
# NEXT_PUBLIC_API_URL=https://piko-protocol-production.up.railway.app
# NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_SITE_URL=https://piko-protocol.app
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_MAPTILER_API_KEY=
# Example styles: streets-v2, outdoor-v2, streets-v2-darkmatter
NEXT_PUBLIC_MAPTILER_STYLE=streets-v2
JWT_SECRET=change-me-to-random-secret
DEMO_ACCESS_KEY=
LOG_LEVEL=info
PORT=3001
