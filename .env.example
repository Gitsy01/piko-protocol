# Database
DATABASE_URL=DATABASE_URL=postgresql://postgres:postgres@localhost:5432/depokemongo
REDIS_URL=redis://localhost:6379

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
# General server signer for Anchor interactions and NFT minting.
ANCHOR_WALLET=./wallet/anchor-wallet.json
# Dedicated PIKO mint authority wallet. Keep this outside the repo in production.
PIKO_MINT_AUTHORITY_WALLET=/secure/path/mint-authority.json
PIKO_MINT_ADDRESS=YOUR_PIKO_TOKEN_MINT_PUBKEY_HERE_1234567890
PIKO_DECIMALS=9
PIKO_DAILY_WALLET_CAP_BASE_UNITS=1000000000000
REWARD_COOLDOWN_SECONDS=60
MERCHANT_REGISTRY_PROGRAM_ID=
QUEST_PROGRAM_ID=
SOLANA_PAY_FALLBACK_RECIPIENT=GvHeQ9NfL7KPLWjXrbgNqE6W5gK4Tz6M3fVhHq7w8Y9Z

# AI
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_SITE_NAME=DePokemonGo
# Agents use Ollama first and fall back to deterministic rules when local inference is unavailable.
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b

# App
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_MAPTILER_API_KEY=
# Example styles: streets-v2, outdoor-v2, streets-v2-darkmatter
NEXT_PUBLIC_MAPTILER_STYLE=streets-v2
JWT_SECRET=change-me-to-random-secret
DEMO_ACCESS_KEY=
PORT=3001
